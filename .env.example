# ── Clerk Auth ────────────────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys

# Frontend (must be prefixed VITE_ so Vite embeds them at build time)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# Backend
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx

# ── Database ──────────────────────────────────────────────────────────────────
# Postgres connection string (Neon, Supabase, Railway, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Razorpay Payments ─────────────────────────────────────────────────────────
# Get these from https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Vercel / Deployment only ──────────────────────────────────────────────────
# NODE_ENV is set automatically by Vercel to "production"
# PORT is set automatically by Vercel; not required in production
# BASE_PATH defaults to "/" when not set (correct for Vercel)
